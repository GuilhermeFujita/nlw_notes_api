{
    "name": "Go",
    "image": "mcr.microsoft.com/devcontainers/go:2-1.25-trixie",

    "runArgs": [
        "--userns=keep-id",
        "--security-opt", "label=disable"
    ],

    "mounts": [
        "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind"
    ],

    "remoteUser": "vscode",

    "features": {},

    "customizations": {
        "vscode": {
            "extensions": [
                "golang.Go"
            ]
        }
    }
}